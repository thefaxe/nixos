# integrate https://www.abuseipdb.com reporting in fail2ban for ssh

sshd.settings = {
        backend = "systemd";
        mode = "aggressive";
        action_abuseipdb = "abuseipdb";
        action = ''%(action_)s
         %(action_abuseipdb)s[abuseipdb_apikey="apikeyhere", abuseipdb_category="18,22"]'';
};
